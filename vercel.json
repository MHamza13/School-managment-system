{
  "version": 2,
  "builds": [
    {
      "src": "index.js",
      "use": "@vercel/node"
    },
    {
      "src": "dist/**",
      "use": "@vercel/static"
    }
  ],
  "rewrites": [
    {
      "source": "/uploads/(.*)",
      "destination": "/uploads/$1"
    },
    {
      "source": "/api/(.*)",
      "destination": "index.js"
    },
    {
      "source": "/((?!api|uploads).*)",
      "destination": "index.js"
    }
  ]
}